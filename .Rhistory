name = "||∇f||",
option = "plasma"
) +
# gradient arrows colored by magnitude
geom_segment(
data = gdf,
aes(x = x, y = y, xend = xend, yend = yend, colour = mag),
inherit.aes = FALSE,
linewidth = 0.6,
arrow = arrow(length = unit(0.10, "cm"))
) +
labs(
title = "Contours and gradient field of f(x,y)=x^2 y",
subtitle = "Arrow color indicates gradient magnitude",
x = "x", y = "y"
)
p
# ---- function and gradient ----
f  <- function(x, y) x^2 + y^2
fx <- function(x, y) 2 * x
fy <- function(x, y) 2 * y
# ---- grid for contours ----
x <- seq(-2, 2, length.out = 500)
y <- seq(-2, 2, length.out = 500)
df <- expand.grid(x = x, y = y) %>%
mutate(z = f(x, y))
# ---- grid for gradient arrows ----
xg <- seq(-2, 2, by = 0.25)
yg <- seq(-2, 2, by = 0.25)
gdf <- expand.grid(x = xg, y = yg) %>%
mutate(
u = fx(x, y),
v = fy(x, y),
mag = sqrt(u^2 + v^2)
)
# normalize direction (so arrows are readable)
gdf <- gdf %>%
mutate(
u2 = u / (mag + 1e-9),
v2 = v / (mag + 1e-9)
)
arrow_scale <- 0.15
gdf <- gdf %>%
mutate(
xend = x + arrow_scale * u2,
yend = y + arrow_scale * v2
)
# ---- contour levels ----
breaks <- seq(0.25, 4, by = 0.25)
# ---- plot ----
p <- ggplot(df, aes(x, y, z = z)) +
# contour circles
geom_contour(breaks = breaks, linewidth = 0.7, colour = "grey30") +
# gradient arrows colored by magnitude
geom_segment(
data = gdf,
aes(x = x, y = y, xend = xend, yend = yend, colour = mag),
inherit.aes = FALSE,
linewidth = 0.6,
arrow = arrow(length = unit(0.10, "cm"))
) +
coord_equal() +
theme_minimal() +
scale_colour_viridis_c(
name = "||∇f||",
option = "viridis"
) +
labs(
title = "Contours and gradient field of f(x,y)=x² + y²",
subtitle = "Gradients are perpendicular to contours and point outward",
x = "x", y = "y"
)
p
