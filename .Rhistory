# ---- function ----
f <- function(x, y) x^2 * y * exp(y)
# ---- grid for contours ----
x <- seq(-2.5, 2.5, length.out = 500)
y <- seq(-2.5, 2.5, length.out = 500)
df <- expand.grid(x = x, y = y) %>%
mutate(z = f(x, y))
# ---- constraint: x^2 + y^2 = 4 ----
theta <- seq(0, 2*pi, length.out = 800)
circle <- data.frame(
x = 2 * cos(theta),
y = 2 * sin(theta)
)
# ---- contour levels ----
# function grows fast for y>0 and changes sign with y,
# so use a symmetric but slightly dense set of levels
breaks <- seq(-5, 5, by = 0.5)
# ---- plot ----
p <- ggplot(df, aes(x, y, z = z)) +
# contour lines
geom_contour(
breaks = breaks,
colour = "grey30",
linewidth = 0.7
) +
# constraint circle
geom_path(
data = circle,
aes(x, y),
inherit.aes = FALSE,
colour = "red",
linewidth = 1.4
) +
coord_equal() +
theme_minimal() +
labs(
title = expression(paste("Contours of ", f(x,y) = x^2 y e^y)),
