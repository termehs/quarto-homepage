# Function z = x^2y
f <- function(x, y) x^2 * y
# Surface grid
n <- 120
x <- seq(-1.5, 1.5, length.out = n)
y <- seq(-1.5, 1.5, length.out = n)
z <- outer(x, y, f)
# Unit circle parameterization
t <- seq(0, 2*pi, length.out = 600)
xc <- cos(t)
yc <- sin(t)
# Projection onto the surface
zc <- f(xc, yc)
# Unit circle in xy-plane (optional reference)
z0 <- rep(0, length(t))
p <- plot_ly() %>%
# Surface
add_surface(
x = x, y = y, z = z,
opacity = 0.85,
showscale = FALSE
) %>%
# Unit circle in xy-plane
add_trace(
x = xc, y = yc, z = z0,
type = "scatter3d",
mode = "lines",
line = list(width = 10, color = "red"),
name = "Unit circle (xy-plane)"
) %>%
layout(
title = "f(x,y) = x²y",
scene = list(
xaxis = list(title = "x"),
yaxis = list(title = "y"),
zaxis = list(title = "z"),
aspectmode = "cube"
)
)
p
# Function
f <- function(x, y) x^2 * y
# --- Parametric unit disk ---
nr <- 120
nt <- 120
r <- seq(0, 1, length.out = nr)
theta <- seq(0, 2*pi, length.out = nt)
R <- matrix(rep(r, each = nt), nrow = nt)
T <- matrix(rep(theta, times = nr), nrow = nt)
X <- R * cos(T)
Y <- R * sin(T)
Z <- f(X, Y)
# --- Boundary: unit circle lifted ---
t <- seq(0, 2*pi, length.out = 600)
xc <- cos(t)
yc <- sin(t)
zc <- f(xc, yc)
plot_ly() %>%
# Surface over unit disk only
add_surface(
x = X, y = Y, z = Z,
opacity = 0.9,
showscale = FALSE
) %>%
# Boundary curve
add_trace(
x = xc, y = yc, z = zc,
type = "scatter3d",
mode = "lines",
line = list(color = "red", width = 10),
name = "Boundary (unit circle)"
) %>%
layout(
scene = list(
xaxis = list(title = "x"),
yaxis = list(title = "y"),
zaxis = list(title = "z"),
aspectmode = "cube"
),
margin = list(l = 0, r = 0, b = 0, t = 0)
)
