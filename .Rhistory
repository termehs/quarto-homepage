setwd("~/Dropbox/ts/uni_konstanz/2023/teaching/statistical-learning/course-material/practicals25/13-pca")
# Original data
X <- matrix(
c(2, 1,
4, 3,
6, 5),
ncol = 2,
byrow = TRUE
)
colnames(X) <- c("x", "y")
rownames(X) <- c("A", "B", "C")
# Center the data
X_centered <- scale(X, center = TRUE, scale = FALSE)
# Compute covariance matrix
Sigma <- cov(X_centered)
# Eigen decomposition
eig <- eigen(Sigma)
# Eigenvectors (PC directions)
v1 <- eig$vectors[,1]  # PC1
v2 <- eig$vectors[,2]  # PC2
# Plot centered data
plot(
X_centered,
asp = 1,
pch = 19,
col = "darkgreen",
xlab = "x (centered)",
ylab = "y (centered)",
main = "PCA: Numeric Example"
)
text(X_centered, labels = rownames(X_centered), pos = 3)
# Draw PC1 and PC2 directions
arrows(0, 0, v1[1]*3, v1[2]*3, col = "red", lwd = 2)
arrows(0, 0, -v1[1]*3, -v1[2]*3, col = "red", lwd = 2)
arrows(0, 0, v2[1]*3, v2[2]*3, col = "blue", lwd = 2)
arrows(0, 0, -v2[1]*3, -v2[2]*3, col = "blue", lwd = 2)
legend(
"topleft",
legend = c("Data points", "PC1", "PC2"),
col = c("darkgreen", "red", "blue"),
pch = c(19, NA, NA),
lwd = c(NA, 2, 2)
)
library(ggplot2)
# Original data
X <- data.frame(
x = c(2, 4, 6),
y = c(1, 3, 5),
label = c("A", "B", "C")
)
# Center the data
X_centered <- transform(
X,
x = x - mean(x),
y = y - mean(y)
)
# Covariance matrix and eigen decomposition
Sigma <- cov(X_centered[, c("x", "y")])
eig <- eigen(Sigma)
# Eigenvectors (PC directions)
v1 <- eig$vectors[, 1]  # PC1
v2 <- eig$vectors[, 2]  # PC2
# Scale arrows for visibility
arrow_scale <- 3
pc_df <- data.frame(
x = c(0, 0),
y = c(0, 0),
xend = c(v1[1], v2[1]) * arrow_scale,
yend = c(v1[2], v2[2]) * arrow_scale,
PC = c("PC1", "PC2")
)
# Plot
ggplot(X_centered, aes(x, y)) +
geom_point(size = 3, color = "darkgreen") +
geom_text(aes(label = label), vjust = -1) +
geom_segment(
data = pc_df,
aes(x = x, y = y, xend = xend, yend = yend, color = PC),
arrow = arrow(length = unit(0.25, "cm")),
linewidth = 1.2
) +
scale_color_manual(values = c("PC1" = "red", "PC2" = "blue")) +
coord_equal() +
labs(
